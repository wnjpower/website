# ─────────────────────────────────────────────
#  우앤주전력 웹사이트 환경변수 템플릿
#  실제 사용 시: cp .env.example .env.local 후 값 채우기
#  .env.local은 절대 git에 커밋하지 말 것
# ─────────────────────────────────────────────

# Supabase — 신규 계정에 프로젝트 생성 후 값 입력.
# (https://supabase.com → Project Settings → API Keys)
#
# 이 앱은 anon(publishable) 키로 INSERT만 한다. service_role 키는 쓰지 않으므로
# 넣을 필요가 없다. (조회는 Supabase 대시보드 Table Editor에서)
#
# ⚠️ 키를 넣기 전에 supabase/schema.sql 을 SQL Editor에서 실행할 것.
#    특히 3번 섹션의 `grant insert ... to anon` 이 빠지면 테이블은 생기지만
#    INSERT가 권한 오류로 거부된다. (2026-04-28부터 신규 프로젝트는
#    public 스키마 테이블이 Data API에 자동 노출되지 않음)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Resend — 계정 이관으로 기존 키/도메인 인증 재사용 안 함. 신규 계정에서 재설정 예정.
# 미설정 상태여도 요청은 실패하지 않음(app/api/quote/route.ts에서 try/catch로 무시됨)
# (https://resend.com)
# 1) resend.com → API Keys → Create API Key
# 2) resend.com → Domains → Add Domain(wnjpower.com) → DNS 레코드 추가 후 인증
RESEND_API_KEY=re_xxx
NOTIFY_TO_EMAIL=wnj-2023@naver.com
NOTIFY_FROM_EMAIL=quote@wnjpower.com

# ─── 카카오 알림톡 (Solapi) ───────────────────────────────────────────────────
# 설정 완료 전까지는 이 섹션을 비워두면 알림톡 없이 이메일만 발송됨.
#
# [설정 순서]
# 1. 카카오 비즈니스 채널 개설 → https://business.kakao.com
#    채널 유형을 '공개 채널'로 전환 + 비즈니스 인증 완료
# 2. Solapi 가입 → https://console.solapi.com
#    [API Key 관리] → API Key / Secret 발급
#    [카카오 채널] → 채널 연동 (채널 검색 ID: @우앤주전력)
#    [알림톡 템플릿] → 아래 두 템플릿 등록 후 카카오 심사 (1~3 영업일)
# 3. 발신번호 등록: [발신번호 관리] → 010-8552-9994 등록 (본인인증 문자)
# 4. 아래 값 입력 후 저장
#
# [알림톡 템플릿 내용 — Solapi 대시보드에 그대로 붙여넣기]
#
# ▶ 신청자 수신용 (SOLAPI_TEMPLATE_TO_REQUESTER):
# ────────────────────────────────────────────
# [우앤주전력] 견적문의 접수 완료
#
# 안녕하세요, #{성함}님.
# 우앤주전력에 견적문의가 정상 접수되었습니다.
#
# ■ 접수 내용
# - 공사 종류: #{공사종류}
# - 접수 일시: #{접수일시}
#
# 1영업일 이내에 담당자가 직접 연락드리겠습니다.
#
# 빠른 연락: 010-8552-9994
# wnjpower.com
# ────────────────────────────────────────────
#
# ▶ 사장님 수신용 (SOLAPI_TEMPLATE_TO_OWNER):
# ────────────────────────────────────────────
# [우앤주전력] 새 견적문의 접수
#
# 고객 문의가 접수되었습니다.
#
# ■ 고객 정보
# - 업체명: #{업체명}
# - 성함: #{성함}
# - 연락처: #{연락처}
# - 공사 종류: #{공사종류}
# - 지역: #{지역}
# - 접수 일시: #{접수일시}
#
# 고객에게 빠른 연락 부탁드립니다!
# ────────────────────────────────────────────

SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_PF_ID=              # Solapi 채널연동 후 발급되는 발신프로필 ID (KA01PF...)
SOLAPI_SENDER_NUMBER=010-8552-9994
SOLAPI_TEMPLATE_TO_REQUESTER=   # 신청자에게 보내는 템플릿 ID (KA01TP...)
SOLAPI_TEMPLATE_TO_OWNER=       # 사장님에게 보내는 템플릿 ID (KA01TP...)
OWNER_MOBILE=010-8552-9994

# (선택) Cloudflare Turnstile — 봇 방지
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# (선택) Google Analytics 4 — 미설정이어도 components/GoogleAnalytics.tsx의 기본값으로 동작함
# 측정 ID는 반드시 'G-'로 시작해야 한다 (접두어가 빠지면 gtag가 조용히 실패)
NEXT_PUBLIC_GA_ID=G-7XRHSS9V0F

# 사이트 메타 — 정규 도메인은 www 포함. 코드 폴백(lib/site.ts)과 반드시 일치시킬 것
NEXT_PUBLIC_SITE_URL=https://www.wnjpower.com
