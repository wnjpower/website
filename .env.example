# ─────────────────────────────────────────────
#  우앤주전력 웹사이트 환경변수 템플릿
#  실제 사용 시: cp .env.example .env.local 후 값 채우기
#  .env.local은 절대 git에 커밋하지 말 것
# ─────────────────────────────────────────────

# Supabase (https://supabase.com → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Resend (https://resend.com)
# 1) resend.com → API Keys → Create API Key
# 2) resend.com → Domains → Add Domain(wnjpower.com) → DNS 레코드 추가 후 인증
RESEND_API_KEY=re_xxx
NOTIFY_TO_EMAIL=wnj-2023@naver.com
NOTIFY_FROM_EMAIL=quote@wnjpower.com

# (선택) Cloudflare Turnstile — 봇 방지
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# (선택) Google Analytics 4
NEXT_PUBLIC_GA_ID=

# 사이트 메타
NEXT_PUBLIC_SITE_URL=https://wnjpower.com
